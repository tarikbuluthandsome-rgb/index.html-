# ── MongoDB Atlas ──────────────────────────────────────────────
# MongoDB Atlas > Connect > Drivers > Connection String
MONGODB_URI=mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/hukukai?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────
# Rastgele uzun bir string - örn: openssl rand -hex 32
JWT_SECRET=buraya_cok_uzun_rastgele_bir_string_yaz

# ── Master Hesap ───────────────────────────────────────────────
MASTER_USERNAME=master
# bcrypt hash - aşağıdaki KURULUM.txt'deki komutla üret
MASTER_PASSWORD_HASH=$2a$12$BURAYA_BCRYPT_HASH_GELECEK

# ── Resend E-posta ─────────────────────────────────────────────
# resend.com > API Keys > yeni anahtar oluştur (eskisini sil!)
RESEND_API_KEY=re_YENI_ANAHTARINI_BURAYA_YAZ
EMAIL_FROM=HukukAI Pro <noreply@hukukai.pro>
EMAIL_TO=tarikbuluthandsome@hotmail.com

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=bot_token_buraya
TELEGRAM_CHAT_ID=chat_id_buraya

# ── Güvenlik ───────────────────────────────────────────────────
# Production'da siteni yaz: https://hukukai.pro
ALLOWED_ORIGIN=*
